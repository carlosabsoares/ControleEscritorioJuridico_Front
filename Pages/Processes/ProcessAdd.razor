@page "/process/add"

@using CEJ_WebApp.Components.Client
@using CEJ_WebApp.Components.LegalProcess
@using CEJ_WebApp.Core.Services
@using System.ComponentModel.DataAnnotations
@using CEJ_WebApp.Model
@using CEJ_WebApp.Model.Dto
@using CEJ_WebApp.Model.Enum
@using CEJ_WebApp.Model.Exemplo
@using MudExRichTextEditor
@using MudBlazor

@inject IClientService _clientService
@inject IExternalService _externalService
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NotificationService Notification
@inject NavigationManager Navigation

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-4">
    
	<!-- Header com indicador de progresso -->
	<MudGrid>
		<MudItem xs="12">
			<MudPaper Class="pa-6 mb-6" Elevation="0" Style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 16px;">
				<MudGrid>
					<MudItem xs="12" md="8">
						<MudText Typo="Typo.h4" Style="color:white" Class="font-weight-bold">Novo Processo</MudText>
						<MudText Typo="Typo.body2" Style="color:white" Class="mt-2 opacity-75">
							Preencha as informações abaixo para registrar um novo processo jurídico
						</MudText>
					</MudItem>
				</MudGrid>
			</MudPaper>
		</MudItem>
	</MudGrid>

	<MudPaper Class="pa-6" Elevation="2" Style="border-radius: 20px;">
		<EditForm Model="@model" OnValidSubmit="Salvar">
			<DataAnnotationsValidator />
			<ValidationSummary />

			<!-- Dados Gerais Section -->
			<MudGrid>
				<MudItem xs="12">
					<MudText Typo="Typo.h6" Class="font-weight-bold mb-4" Color="Color.Primary">
						<MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="mr-2" />
						Dados Gerais
					</MudText>
					<MudDivider Class="mb-4" />
				</MudItem>
			</MudGrid>

			<MudGrid Spacing="3">
				<!-- Linha 1 -->
				<MudItem xs="12" sm="6" md="4">
					<MudTextField Label="Número do Processo"
								  Variant="Variant.Outlined"
								  Margin="Margin.Dense"
								  FullWidth="true"
								  @bind-Value="model.NumeroProcesso"
								  Placeholder="0000000-00.0000.0.00.0000"
								  Adornment="Adornment.Start"
								  AdornmentIcon="@Icons.Material.Filled.Numbers" />
				</MudItem>

				<MudItem xs="12" sm="6" md="4">
					<MudSelect T="string"
							   Label="Tipo de Ação"
							   Variant="Variant.Outlined"
							   Margin="Margin.Dense"
							   @bind-Value="model.TipoAcao"
							   AdornmentIcon="@Icons.Material.Filled.Gavel">
						@foreach (var tipo in TiposAcao)
						{
							<MudSelectItem Value="@tipo">@tipo</MudSelectItem>
						}
					</MudSelect>
				</MudItem>

				<MudItem xs="12" sm="6" md="4">
					<MudDatePicker Label="Data de Abertura"
								   Variant="Variant.Outlined"
								   Margin="Margin.Dense"
								   @bind-Date="model.DataAbertura"
								   AdornmentIcon="@Icons.Material.Filled.CalendarToday" />
				</MudItem>

				<!-- Linha 2 -->
				<MudItem xs="12" sm="6" md="4">
					<MudSelect T="PriorityType"
							   Label="Prioridade"
							   Variant="Variant.Outlined"
							   Margin="Margin.Dense"
							   @bind-Value="model.Prioridade"
							   AdornmentIcon="@Icons.Material.Filled.PriorityHigh"
							   HideSelectedValue="true">
        
						<MudSelectItem Value="PriorityType.Alta">
							<div style="display: flex; align-items: center; gap: 8px;">
								<MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Size="Size.Small" />
								<span>Alta</span>
							</div>
						</MudSelectItem>
        
						<MudSelectItem Value="PriorityType.Media">
							<div style="display: flex; align-items: center; gap: 8px;">
								<MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" Size="Size.Small" />
								<span>Média</span>
							</div>
						</MudSelectItem>
        
						<MudSelectItem Value="PriorityType.Baixa">
							<div style="display: flex; align-items: center; gap: 8px;">
								<MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
								<span>Baixa</span>
							</div>
						</MudSelectItem>
					</MudSelect>
				</MudItem>

				<MudItem xs="12" sm="6" md="4">
					<MudTextField Label="Vara/Comarca Principal"
								  Variant="Variant.Outlined"
								  Margin="Margin.Dense"
								  FullWidth="true"
								  @bind-Value="model.VaraComarca"
								  AdornmentIcon="@Icons.Material.Filled.LocationOn" />
				</MudItem>

				<MudItem xs="12" sm="6" md="4">
					<MudTextField Label="Vara/Comarca Secundária"
								  Variant="Variant.Outlined"
								  Margin="Margin.Dense"
								  FullWidth="true"
								  @bind-Value="model.VaraComarca2"
								  AdornmentIcon="@Icons.Material.Filled.LocationCity" />
				</MudItem>

				<!-- Linha 3 -->
				<MudItem xs="12" sm="6" md="4">
					<MudSelect T="string"
							   Label="Status"
							   Variant="Variant.Outlined"
							   Margin="Margin.Dense"
							   @bind-Value="model.Status"
							   AdornmentIcon="@Icons.Material.Filled.TrackChanges"
							   HideSelectedValue="true">
        
						<!-- Itens do dropdown -->
						@foreach (var status in StatusList)
						{
							<MudSelectItem Value="@status">
								<div style="display: flex; align-items: center; gap: 8px;">
									@if (status == "Em andamento")
									{
										<MudIcon Icon="@Icons.Material.Filled.PlayArrow" Color="Color.Info" Size="Size.Small" />
									}
									else if (status == "Suspenso")
									{
										<MudIcon Icon="@Icons.Material.Filled.Pause" Color="Color.Warning" Size="Size.Small" />
									}
									else if (status == "Finalizado")
									{
										<MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
									}
									else if (status == "Arquivado")
									{
										<MudIcon Icon="@Icons.Material.Filled.Archive" Color="Color.Default" Size="Size.Small" />
									}
									<span>@status</span>
								</div>
							</MudSelectItem>
						}
					</MudSelect>
				</MudItem>

				<MudItem xs="12" sm="6" md="4">
					<MudDatePicker Label="Prazo Processual"
								   Variant="Variant.Outlined"
								   Margin="Margin.Dense"
								   @bind-Date="model.PrazoProcessual"
								   AdornmentIcon="@Icons.Material.Filled.Schedule" />
				</MudItem>

				<MudItem xs="12" sm="12" md="4" Class="d-flex align-center">
					<MudCheckBox T="bool"
								 @bind-Checked="model.AtivarAlerta"
								 Label="Ativar alerta de prazo"
								 Color="Color.Primary"
								 Class="mt-2" />
				</MudItem>

				<!-- Cliente Section -->
				<MudItem xs="12">
					<MudText Typo="Typo.h6" Class="font-weight-bold mt-4 mb-4" Color="Color.Primary">
						<MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Small" Class="mr-2" />
						Informações do Cliente
					</MudText>
					<MudDivider Class="mb-4" />
				</MudItem>

				<MudItem xs="12" md="12">
					<MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
						<MudSelect T="ClientDto"
								   Label="Selecione o cliente"
								   Variant="Variant.Outlined"
								   Margin="Margin.Dense"
								   @bind-Value="model.Client"
								   Style="flex: 1;"
								   AdornmentIcon="@Icons.Material.Filled.Person">
    
							@foreach (var client in clientsDto)
							{
								<MudSelectItem Value="@client">
									<MudStack Direction="Direction.Row" AlignItems="AlignItems.Start" Spacing="2">
										<div>
											<div>@client.Name</div>
										</div>
									</MudStack>
								</MudSelectItem>
							}
						</MudSelect>

						<MudFab Color="Color.Primary"
								StartIcon="@Icons.Material.Filled.Add"
								Size="Size.Medium"
								title="Adicionar um cliente"
								OnClick="OpenAddClient" />
						
						@* 						<MudTooltip Text="Adicionar novo cliente">
							<MudFab Icon="@Icons.Material.Filled.Add"
									Color="Color.Primary"
									Size="Size.Small"
									OnClick="OpenAddClient"
									Class="mt-1" />
						</MudTooltip> *@
					</MudStack>
				</MudItem>

				<!-- Descrição -->
				<MudItem xs="12">
					<MudText Typo="Typo.h6" Class="font-weight-bold mt-4 mb-4" Color="Color.Primary">
						<MudIcon Icon="@Icons.Material.Filled.Description" Size="Size.Small" Class="mr-2" />
						Descrição do Processo
					</MudText>
					<MudDivider Class="mb-4" />
				</MudItem>

				<MudItem xs="12">
					<MudPaper Class="pa-4" Elevation="1" Style="border-radius: 12px; background-color: #f8f9fa;">
						<div style="min-height: 250px;">
							<MudExRichTextEdit Value="@model.TipoAcaoDescricao"
											   ValueChanged="@(v => model.TipoAcaoDescricao = v)"
											   Style="min-height: 250px; border: none; background: white; border-radius: 8px;" />
						</div>
					</MudPaper>
				</MudItem>

				<!-- Tabs Section -->
				<MudItem xs="12">
					<MudText Typo="Typo.h6" Class="font-weight-bold mt-4 mb-4" Color="Color.Primary">
						<MudIcon Icon="@Icons.Material.Filled.Folder" Size="Size.Small" Class="mr-2" />
						Informações Complementares
					</MudText>
					<MudDivider Class="mb-4" />
				</MudItem>

				<MudItem xs="12">
					<MudTabs Outlined="true"
							 Class="mud-tab-border"
							 Elevation="0"
							 Style="border-radius: 12px; overflow: hidden;">
                        
						<!-- Substitua o conteúdo do MudTabPanel "Partes Envolvidas" por: -->
						<MudTabPanel Text="Partes Envolvidas" Icon="@Icons.Material.Filled.PeopleAlt">
							<MudContainer Class="pa-4">
								<MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
									<MudText Typo="Typo.subtitle1" Class="font-weight-bold">Partes Adicionadas</MudText>
									<MudButton Variant="Variant.Filled"
											   Color="Color.Primary"
											   StartIcon="@Icons.Material.Filled.Add"
											   OnClick="OpenAddParteDialog">
										Nova Parte
									</MudButton>
								</MudStack>

								@if (listaPartes.Any())
								{
									<MudTable Items="@listaPartes"
											  Hover="true"
											  Breakpoint="Breakpoint.Sm"
											  Elevation="0"
											  Dense="true">
										<HeaderContent>
											<MudTh>Tipo</MudTh>
											<MudTh>Nome/Razão Social</MudTh>
											<MudTh>CPF/CNPJ</MudTh>
											<MudTh>Email</MudTh>
											<MudTh>Telefone</MudTh>
											<MudTh>Ações</MudTh>
										</HeaderContent>
										<RowTemplate Context="item">
											<MudTd DataLabel="Tipo">
												<MudChip T="string" Size="Size.Small" Color="@GetTipoColor(item.Tipo)" Variant="MudBlazor.Variant.Outlined">
													<MudText>@item.Tipo</MudText>
												</MudChip>
											</MudTd>
											<MudTd DataLabel="Nome/Razão Social">
												<MudText>@item.Nome</MudText>
											</MudTd>
											<MudTd DataLabel="CPF/CNPJ">
												<MudText>@item.Documento</MudText>
											</MudTd>
											<MudTd DataLabel="Email">
												<MudText>@item.Email</MudText>
											</MudTd>
											<MudTd DataLabel="Telefone">
												<MudText>@item.Telefone</MudText>
											</MudTd>
											<MudTd DataLabel="Ações">
												<MudText>
													<MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary" OnClick="() => EditParte(item)" />
													<MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="() => RemoveParte(item)" />
												</MudText>
											</MudTd>
										</RowTemplate>
									</MudTable>
			
									<MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">
										Total de partes: @listaPartes.Count
									</MudText>
								}
								else
								{
									<MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
										<MudIcon Icon="@Icons.Material.Filled.Info" Class="mr-2" />
										Nenhuma parte adicionada. Clique em "Nova Parte" para começar.
									</MudAlert>
								}
							</MudContainer>
						</MudTabPanel>
                        
						<MudTabPanel Text="Documentos"
									 Icon="@Icons.Material.Filled.UploadFile">
							<MudContainer Class="pa-4">
								<MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
									<MudText>Faça upload dos documentos relacionados a este processo.</MudText>
								</MudAlert>
                                
								<MudFileUploader Variant="Variant.Outlined"
												 Label="Selecione os arquivos"
												 Accept=".pdf,.doc,.docx,.jpg,.png"
												 Multiple="true"
												 Class="mt-2" />
							</MudContainer>
						</MudTabPanel>
                        
						<MudTabPanel Text="Movimentação"
									 Icon="@Icons.Material.Filled.Timeline">
							<MudContainer Class="pa-4">
								<MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
									<MudText>Histórico de movimentações e andamentos do processo.</MudText>
								</MudAlert>
                                
								<MudTimeline Bullets="TimelineBullet.Icon" Elevation="0">
									<MudTimelineItem Icon="@Icons.Material.Filled.Add" Color="Color.Primary">
										<MudText Typo="Typo.caption" Class="text-muted">Hoje, 10:30</MudText>
										<MudText>Processo criado no sistema</MudText>
									</MudTimelineItem>
								</MudTimeline>
							</MudContainer>
						</MudTabPanel>
                        
						<MudTabPanel Text="Financeiro"
									 Icon="@Icons.Material.Filled.MonetizationOn">
							<MudContainer Class="pa-4">
								<MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
									<MudText>Informações financeiras e custas processuais.</MudText>
								</MudAlert>
                                
								<MudGrid>
									<MudItem xs="12" md="6">
										<MudTextField T="decimal"
													  Label="Valor da Causa"
													  Variant="Variant.Outlined"
													  Adornment="Adornment.Start"
													  AdornmentText="R$" />
									</MudItem>
									<MudItem xs="12" md="6">
										<MudTextField T="decimal"
													  Label="Custas Processuais"
													  Variant="Variant.Outlined"
													  Adornment="Adornment.Start"
													  AdornmentText="R$" />
									</MudItem>
								</MudGrid>
							</MudContainer>
						</MudTabPanel>
					</MudTabs>
				</MudItem>

				<!-- Action Buttons -->
				<MudItem xs="12">
					<MudStack Row="true" Justify="Justify.FlexEnd" Spacing="2" Class="mt-6 pt-4">
						<MudButton Variant="Variant.Text"
								   Color="Color.Default"
								   OnClick="Cancelar">
							Cancelar
						</MudButton>
						<MudButton Variant="Variant.Filled"
								   Color="Color.Primary"
								   Type="Submit"
								   StartIcon="@Icons.Material.Filled.Save">
							Salvar Processo
						</MudButton>
					</MudStack>
				</MudItem>
			</MudGrid>
		</EditForm>
	</MudPaper>
</MudContainer>

@code {
	private ProcessoModel model = new();
	public int Radio_Size { get; set; } = 3;
	private List<ClientDto> clientsDto = new();
	private string searchString = "";
	private bool loading = false;
	private bool _dialogOpen = false;

	protected override async Task OnInitializedAsync()
	{
		await LoadManufactures();
	}

	// Adicione esta lista às suas variáveis
	private List<PartyLegalProcessEntity> listaPartes = new();
	private PartyLegalProcessEntity parte = new();

	private async Task OpenAddParteDialog()
	{

		var partyLegalProcess = new PartyLegalProcessEntity()
		{
			Address = new AddressEntity()
		};

		var parameters = new DialogParameters
			{
				{ "partiesModel", partyLegalProcess },
				{ "InsertMode", true}
			};



		var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
		var dialog = await DialogService.ShowAsync<PartiesLegalProcessDialog>("",parameters, options);
		var result = await dialog.Result;

		if (!result.Canceled && result.Data is PartyLegalProcessEntity novaParte)
		{
			listaPartes.Add(novaParte);
			listaPartes.OrderBy(z => z.Tipo);
			StateHasChanged();
		}
	}

	private Color GetTipoColor(string tipo)
	{
		return tipo switch
		{
			"Autor" => Color.Info,
			"Réu" => Color.Error,
			"Advogado" => Color.Success,
			"Testemunha" => Color.Warning,
			"Assistente" => Color.Secondary,
			"Perito" => Color.Primary,
			_ => Color.Default
		};
	}

	async Task LoadManufactures()
	{
		try
		{
			loading = true;
			var task = GetClientsDtoAsync();
			await Task.WhenAll(task, Task.Delay(300));
			clientsDto = task.Result;
		}
		finally
		{
			loading = false;
		}
	}

	private async Task EditParte(PartyLegalProcessEntity parte)
	{
		var parameters = new DialogParameters
			{
				{ "partiesModel", parte },
				{ "InsertMode", false }
			};

		var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
		var dialog = await DialogService.ShowAsync<PartiesLegalProcessDialog>("", parameters, options);
		var result = await dialog.Result;

		if (!result.Canceled && result.Data is PartyLegalProcessEntity novaParte)
		{
			StateHasChanged();
		}
		
	}

	private async Task RemoveParte(PartyLegalProcessEntity parte)
	{
		// Opcional: Confirmar antes de remover
		var confirm = await DialogService.ShowMessageBox(
			"Confirmar",
			"Tem certeza que deseja remover esta parte?",
			yesText: "Sim",
			cancelText: "Não");
    
		if (confirm == true)
		{
			// Remove da lista
			listaPartes.RemoveAll(p => p.Nome == parte.Nome);
			StateHasChanged();
		}
	}

	private async Task OpenAddClient()
	{
		if (_dialogOpen) return;
		_dialogOpen = true;

		try
		{
			var client = new ClientEntity()
			{
				Name = string.Empty,
				DocumentType = DocumentType.CPF,
				Address = new AddressEntity()
			};

			var parameters = new DialogParameters
			{
				{ "Client", client },
				{ "InsertMode", true }
			};

			var options = new DialogOptions
			{
				CloseOnEscapeKey = true,
				MaxWidth = MaxWidth.Large,
				FullWidth = true
			};

			var dialog = await DialogService.ShowAsync<ClientDialog>("Novo Cliente", parameters, options);
			var result = await dialog.Result;

			if (!result.Canceled)
				await ReloadClients();
		}
		finally
		{
			_dialogOpen = false;
		}
	}

	private async Task ReloadClients()
	{
		try
		{
			loading = true;
			clientsDto = await GetClientsDtoAsync();
			StateHasChanged();
		}
		finally
		{
			loading = false;
		}
	}

	private async Task<List<ClientDto>> GetClientsDtoAsync()
	{
		var clientsEntity = await _clientService.GetClientAllAsync();
		return clientsEntity.Select(x => new ClientDto()
		{
			Uuid = x.Uuid,
			Name = x.Name,
			Email = x.Email,
			Active = x.Active,
			CellPhone = x.CellPhoneNumber,
			Phone = x.PhoneNumber,
		}).ToList();
	}

	private List<string> TiposAcao = new()
	{
		"Ação Civil",
		"Ação Trabalhista",
		"Ação Criminal",
		"Ação Família",
		"Ação Empresarial"
	};

	private List<string> StatusList = new()
	{
		"Em andamento",
		"Suspenso",
		"Finalizado",
		"Arquivado"
	};

	private void Salvar()
	{
		Snackbar.Add("Processo salvo com sucesso!", Severity.Success);
		Console.WriteLine("Salvo com sucesso!");
	}

	private void Cancelar()
	{
		Snackbar.Add("Operação cancelada", Severity.Normal);
		Navigation.NavigateTo("/process");
	}
}