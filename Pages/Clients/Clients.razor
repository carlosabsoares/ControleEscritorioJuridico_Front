@page "/clients"
@page "/clients/Index"
@using CEJ_WebApp.Components.Users
@using CEJ_WebApp.Core.Services
@using CEJ_WebApp.Model
@using CEJ_WebApp.Model.Dto
@using CEJ_WebApp.Model.Enum
@using CEJ_WebApp.Components.Client

@inject IClientService _clientService
@inject IExternalService _externalService
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NotificationService Notification

<MudDialogProvider />

<ModalClient @ref="clientModal"
			 Client="@client"
			 ModalTitle="@modalTitle"
			 InsertMode="insertMode"
			 OnSaved="ReloadGrid" />

<ClientActiveDeactiveModal @ref="clientActiveDeactiveModal"
						   Client="@client"
						   ModalTitle="@modalTitle"
						   DeactiveMode="deactiveMode"
						   OnSaved="ReloadGrid" />

<div class="card">
	<div class="card-header">
		<MudStack Row="true"
				  Justify="Justify.SpaceBetween"
				  AlignItems="MudBlazor.AlignItems.Center"
				  Class="mb-3">

			<h4>Cliente</h4>

			<MudFab Color="Color.Tertiary"
					StartIcon="@Icons.Material.Filled.Add"
					Label="Cliente"
					OnClick="OpenModalAsync" />

		</MudStack>
	</div>

	<div class="card-body">
		<MudTable @ref="gridClient"
				  T="ClientDto"
				  Items="@clientsDto"
				  Filter="new Func<ClientDto, bool>(FilterClients)"
				  FilterMode="FilterMode.Filterable"
				  FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
				  Hover="true"
				  Bordered="true"
				  Striped="true"
				  Loading="@loading"
				  Breakpoint="Breakpoint.Sm"
				  Height="400px"
				  FixedHeader="true"
				  HorizontalScrollbar="true">

			<!-- Toolbar com filtro -->
			<ToolBarContent>
				<MudText Typo="Typo.subtitle1">Lista de Clientes</MudText>
				<MudSpacer />
				<MudTextField @bind-Value="searchString"
							  Placeholder="Pesquisar..."
							  Variant="MudBlazor.Variant.Outlined"
							  Adornment="Adornment.Start"
							  AdornmentIcon="@Icons.Material.Filled.Search"
							  IconSize="Size.Small"
							  DebounceInterval="300"
							  Immediate="true"
							  Class="mt-0" />
			</ToolBarContent>

			<!-- Cabeçalho da tabela -->
			<HeaderContent>
				<MudTh><MudTableSortLabel SortBy="new Func<ClientDto, object>(x => x.Name)">Nome</MudTableSortLabel></MudTh>
				<MudTh><MudTableSortLabel SortBy="new Func<ClientDto, object>(x => x.Email)">Email</MudTableSortLabel></MudTh>
				<MudTh><MudTableSortLabel SortBy="new Func<ClientDto, object>(x => x.Phone)">Telefone</MudTableSortLabel></MudTh>
				<MudTh><MudTableSortLabel SortBy="new Func<ClientDto, object>(x => x.CellPhone)">Celular</MudTableSortLabel></MudTh>
				<MudTh Style="width: 120px; text-align: center;">Ações</MudTh>
			</HeaderContent>

			<!-- Linhas da tabela -->
			<RowTemplate>
				<MudTd DataLabel="Nome">@context.Name</MudTd>
				<MudTd DataLabel="Email">@context.Email</MudTd>
				<MudTd DataLabel="Telefone">@context.Phone</MudTd>
				<MudTd DataLabel="Celular">@context.CellPhone</MudTd>
				<MudTd DataLabel="Ações" Style="text-align: center;">
					<MudStack Row="true" Spacing="1" Justify="Justify.Center">
						@if (context.Active)
						{
							<!-- Botão Alterar -->
							<MudTooltip Text="Alterar">
								<MudIconButton Icon="@Icons.Material.Filled.Edit"
											   Color="Color.Primary"
											   Size="Size.Small"
											   OnClick="@(async () => await OnShowModalEditClick(context))" />
							</MudTooltip>

							<!-- Botão Desativar -->
							<MudTooltip Text="Desativar">
								<MudIconButton Icon="@Icons.Material.Filled.Delete"
											   Color="Color.Error"
											   Size="Size.Small"
											   OnClick="@(async () => await OnShowModalDeleteClick(context))" />
							</MudTooltip>
						}
						else
						{
							<!-- Botão Reativar -->
							<MudTooltip Text="Reativar">
								<MudIconButton Icon="@Icons.Material.Filled.Refresh"
											   Color="Color.Info"
											   Size="Size.Small"
											   OnClick="@(async () => await OnShowModalReactiveClick(context))" />
							</MudTooltip>
						}

						<MudTooltip Text="Processos">
							<MudIconButton Icon="@Icons.Material.Filled.Balance"
										   Style="color:#9E9E9E"
										   Size="Size.Small"
										   OnClick="@(async () => await OnShowModalEditClick(context))" />
						</MudTooltip>

						<MudTooltip Text="Financeiro">
							<MudIconButton Icon="@Icons.Material.Filled.Paid"
										   Style="color:#43A047"
										   Size="Size.Small"

										   OnClick="@(async () => await OnShowModalEditClick(context))" />
						</MudTooltip>
					</MudStack>
				</MudTd>
			</RowTemplate>
			<!-- Paginação -->
			<PagerContent>
				<MudTablePager PageSizeOptions="new int[] { 5, 10, 25, 50 }" />
			</PagerContent>

			<!-- Mensagem quando não há dados -->
			<NoRecordsContent>
				<MudText Align="Align.Center">Nenhum cliente encontrado</MudText>
			</NoRecordsContent>

			<!-- Loading indicator -->
			<LoadingContent>
				<MudText Align="Align.Center">Carregando...</MudText>
			</LoadingContent>

		</MudTable>
	</div>
</div>
@code {
	[Inject]
	public ISnackbar SnackbarService { get; set; } = null!;

	private MudTable<ClientDto> gridClient = new();
	private List<ClientDto> clientsDto = new();
	private string searchString = "";
	private bool loading = false;

	private ModalClient clientModal = default!;
	private ClientActiveDeactiveModal clientActiveDeactiveModal = default!;
	private bool insertMode = false;
	private bool deactiveMode = false;
	private string modalTitle = string.Empty;


	ClientEntity client = new ClientEntity();

	protected override async Task OnInitializedAsync()
	{
		await LoadManufactures();
	}

	async Task LoadManufactures()
	{
		clientsDto = await GetClientsDtoAsync();
	}

	private bool FilterClients(ClientDto client)
	{
		if (string.IsNullOrWhiteSpace(searchString))
			return true;

		return client.Name?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true ||
						client.Email?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true ||
						client.CellPhone?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true ||
						client.Phone?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true;
	}

	private async Task OnShowModalEditClick(ClientDto data)
	{

		var responseClient = await _clientService.GetClientByUuidAsync(data.Uuid);

		if (responseClient == null || string.IsNullOrEmpty(responseClient.Name))
			Notification.ExibirMensagem("Error ao recuperar cliente.", Severity.Error);

		client = responseClient;

		clientModal.Client = client;
		clientModal.InsertMode = false;
		clientModal.ModalTitle = "Alterar cliente";

		await clientModal.ShowAsync();
	}

	private async Task OnShowModalReactiveClick(ClientDto data)
	{
		deactiveMode = false;

		var responseClient = await _clientService.GetClientByUuidAsync(data.Uuid);

		if (responseClient == null || string.IsNullOrEmpty(responseClient.Name))
			Notification.ExibirMensagem("Error ao recuperar cliente.", Severity.Error);

		client = responseClient;

		clientActiveDeactiveModal.Client = client;
		clientActiveDeactiveModal.DeactiveMode = deactiveMode;
		clientActiveDeactiveModal.ModalTitle = "Reativar cliente";

		await clientActiveDeactiveModal.ShowAsync();
	}

	private async Task OnShowModalDeleteClick(ClientDto data)
	{
		deactiveMode = true;

		var responseClient = await _clientService.GetClientByUuidAsync(data.Uuid);

		if (responseClient == null || string.IsNullOrEmpty(responseClient.Name))
			Notification.ExibirMensagem("Error ao recuperar cliente.", Severity.Error);

		client = responseClient;

		clientActiveDeactiveModal.Client = client;
		clientActiveDeactiveModal.DeactiveMode = deactiveMode;
		clientActiveDeactiveModal.ModalTitle = "Deletar cliente";

		await clientActiveDeactiveModal.ShowAsync();

		//await modalUpdate.ShowAsync();
		//await modalScreen.ShowAsync();
	}

	private async Task ReloadGrid()
	{
		await LoadManufactures();
		await gridClient.ReloadServerData();
	}

	private async Task<List<ClientDto>> GetClientsDtoAsync()
	{
		var clientsEntity = await _clientService.GetClientAllAsync();

		return clientsEntity.Select(x => new ClientDto()
		{
			Uuid = x.Uuid,
			Name = x.Name,
			Email = x.Email,
			Active = x.Active,
			CellPhone = x.CellPhoneNumber,
			Phone = x.PhoneNumber,
		}).ToList();
	}

	private async Task OpenModalAsync()
	{
		client = new ClientEntity()
		{
			Name = string.Empty,
			Address = new AddressEntity()
		};

		insertMode = true;
		modalTitle = "Inserir cliente";

		await clientModal.ShowAsync();
	}
}