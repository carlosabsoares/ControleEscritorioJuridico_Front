@inherits LoginPage
@layout AutenticaLayout
@page "/login"

<EditForm Model="@InputRequest" OnValidSubmit="OnValidSubmitAsync">
    <DataAnnotationsValidator />

    <MudTextField Label="Usuário"
                  HelperText="Campo obrigatório - informe o nome do usuário"
                  RequiredError="Favor informar o nome do usuário"
                  @bind-Value="InputRequest.Email"
                  For="@(() => InputRequest.Email)"
                  Variant="Variant.Outlined"
                  Required="true" />

    <MudTextField Label="Senha"
                  HelperText="Campo obrigatório - informe a senha"
                  RequiredError="Favor informar a senha"
                  @bind-Value="InputRequest.Password"
                  For="@(() => InputRequest.Password)"
                  InputType="InputType.Password"
                  Variant="Variant.Outlined"
                  Required="true" />

    <MudButton ButtonType="MudBlazor.ButtonType.Submit"
               Variant="Variant.Filled"
               Disabled="@isLoading"
               Class="btn my-5 fw-bold btn-lg sign-up rounded-5 px-5 fs-6">

        @if (isLoading)
        {
            <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="me-2" />
            <span>Entrando...</span>
        }
        else
        {
            <span>Login</span>
        }

    </MudButton>
</EditForm>