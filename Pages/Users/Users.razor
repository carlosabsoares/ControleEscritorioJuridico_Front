@page "/users"
@page "/users/Index"
@using CEJ_WebApp.Model
@using CEJ_WebApp.Model.Dto
@using CEJ_WebApp.Model.Enum
@inject IUserService _userService
@inject IExternalService _externalService
@inject IJSRuntime JS
@inject NotificationService NotificationService
@inject ISnackbar Snackbar


<Modal @ref="modalScreen" title=@modalTitle
	   UseStaticBackdrop="true"
	   CloseOnEscape="false"
	   IsVerticallyCentered="true"
	   Size="ModalSize.Large">
	<BodyTemplate>
		@* <EditForm Model="@user" OnValidSubmit="@OnIncludeUser"> *@
		<EditForm Model="@user">
			<DataAnnotationsValidator />

			<div class="row">
				<!-- Coluna Nome -->
				<div class="col-md-6">
					<div class="form-group">
						<label>Nome</label>
						<InputText id="txtUserName" class="form-control" @bind-Value=@user.Name />
						<ValidationMessage For="@(() => user.Name)" />
					</div>
				</div>

				<!-- Coluna Perfil -->
				<div class="col-md-6">
					<div class="form-group">
						<label>Perfil</label>
						<InputSelect class="form-select" @bind-Value="user.Role">
							@foreach (var role in Enum.GetValues<UserRoleType>())
							{
								<option value="@role">@role</option>
							}
						</InputSelect>
					</div>
				</div>
			</div>

			<div class="row">
				<!-- Coluna Email -->
				<div class="col-md-6">
					<div class="form-group">
						<label>Email</label>
						<InputText id="txtUserEmail" class="form-control" @bind-Value=@user!.Email />
						<ValidationMessage For="@(() => user.Email)" />
					</div>
				</div>

				<!-- Coluna Password -->
				<div class="col-md-6">
					<div class="form-group @(insertMode ? "" : "invisible")">
						<label>Senha</label>
						<PasswordInput id="txtUserPassword"
									   class="form-control"
									   @bind-Value="user!.Password" />
						<ValidationMessage For="@(() => user.Password)" />
					</div>
				</div>
			</div>

			<div class="card">
				<h4 class="card-header">Endereço</h4>
				<div class="card-body">

					<!-- Coluna CEP -->
					<div class="row">
						<div class="input-group">
							<RadzenMask @ref="zipMask"
										style="max-width: 180px;"
										Mask="*****-***"
										CharacterPattern="[0-9]"
										Placeholder="00000-000"
										@bind-Value="@user.Address.ZipCode"
										class="form-control" />

							<button class="btn btn-primary" @onclick="OnFindCepClick">
								🔍 Pesquisar
							</button>
						</div>
					</div>
					<div class="row">
						<!-- Coluna Logradouro -->
						<div class="col-md-6">
							<div class="form-group">
								<label>Logradouro</label>
								<InputText id="txtUserStreet" class="form-control" @bind-Value=@user!.Address!.Street />
								<ValidationMessage For="@(() => user!.Address!.Street)" />
							</div>
						</div>
						<!-- Coluna Numero -->
						<div class="col-md-3">
							<div class="form-group">
								<label>Numero</label>
								<InputText id="txtUserNumber" type="number"
										   inputmode="numeric"
										   pattern="[0-9]*" class="form-control" @bind-Value=@user!.Address!.Number />
								<ValidationMessage For="@(() => user!.Address!.Number)" />
							</div>
						</div>
						<!-- Coluna Complemento -->
						<div class="col-md-3">
							<div class="form-group">
								<label>Complemento</label>
								<InputText id="txtUserComplement" class="form-control" @bind-Value=@user!.Address!.Complement />
								<ValidationMessage For="@(() => user!.Address!.Complement)" />
							</div>
						</div>
					</div>
					<div class="row">
						<!-- Coluna Bairro -->
						<div class="col-md-5">
							<div class="form-group">
								<label>Bairro</label>
								<InputText id="txtUserNeighborhood" class="form-control" @bind-Value=@user!.Address!.Neighborhood />
								<ValidationMessage For="@(() => user!.Address!.Neighborhood)" />
							</div>
						</div>
						<!-- Coluna Cidade -->
						<div class="col-md-5">
							<div class="form-group">
								<label>Cidade</label>
								<InputText id="txtUserCity" class="form-control" @bind-Value=@user!.Address!.City />
								<ValidationMessage For="@(() => user!.Address!.City)" />
							</div>
						</div>
						<!-- Coluna Estado -->
						<div class="col-md-2">
							<div class="form-group">
								<label>Estado</label>
								<InputSelect class="form-select" @bind-Value="user!.Address!.State">
									@foreach (var uf in Enum.GetValues<UfType>())
									{
										<option value="@uf">@uf.ToString()</option>
									}
								</InputSelect>
							</div>
						</div>
					</div>
				</div>
			</div>


		</EditForm>

	</BodyTemplate>
	<FooterTemplate>
		<Button Color="ButtonColor.Secondary" @onclick="OnHideModalInsertClick">
			<Icon Name="IconName.DoorClosed" /> Fechar
		</Button>
		<Button Color="ButtonColor.Primary" @onclick="OnPersisteModalUser">
			<Icon Name="IconName.Save" /> Salvar
		</Button>

	</FooterTemplate>
</Modal>

<Modal @ref="modalDeactiveReactive" title=@modalTitle
	   UseStaticBackdrop="true"
	   CloseOnEscape="false"
	   IsVerticallyCentered="true"
	   Size="ModalSize.Large">
	<BodyTemplate>
		@* <EditForm Model="@user" OnValidSubmit="@OnIncludeUser"> *@
		<EditForm Model="@user">
			<DataAnnotationsValidator />

			<div class="row">
				<!-- Coluna Nome -->

				<div class="col-md-6">
					<div class="form-group">
						@if (deactiveMode)
						{
							<label>Confirma a desativação do usuário abaixo? </label>
						}
						else
						{
							<label>Confirma a reativação do usuário abaixo? </label>
						}
						
						<InputText id="txtUserName" class="form-control" @bind-Value=@user.Name />
						<ValidationMessage For="@(() => user.Name)" />
					</div>
				</div>
			</div>
		</EditForm>

	</BodyTemplate>
	<FooterTemplate>
		<Button Color="ButtonColor.Secondary" @onclick="OnHideModalDeactiveClick">Não</Button>
		<Button Color="ButtonColor.Primary" @onclick="OnPersisteDeleteModalUser"> Sim </Button>

	</FooterTemplate>
</Modal>



<div class="card">
	<div class="card-header">

		<MudStack Row="true"
				  Justify="Justify.SpaceBetween"
				  AlignItems="MudBlazor.AlignItems.Center"
				  Class="mb-3">

			<h4>Usuário</h4>

			<MudFab Color="Color.Tertiary"
					StartIcon="@Icons.Material.Filled.Add"
					Label="Usuário"
					OnClick="OnShowModalInsertClick" />

		</MudStack>



	</div>
	<div class="card-body">

		<MudTable @ref="gridUser"
				  T="UserDto"
				  Items="@usersDto"
				  Filter="new Func<UserDto, bool>(FilterUsers)"
				  FilterMode="FilterMode.Filterable"
				  FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
				  Hover="true"
				  Bordered="true"
				  Striped="true"
				  Loading="@loading"
				  Breakpoint="Breakpoint.Sm"
				  Height="400px"
				  FixedHeader="true"
				  HorizontalScrollbar="true">

			<!-- Toolbar com filtro -->
			<ToolBarContent>
				<MudText Typo="Typo.subtitle1">Lista de Usuários</MudText>
				<MudSpacer />
				<MudTextField @bind-Value="searchString"
							  Placeholder="Pesquisar..."
							  Variant="MudBlazor.Variant.Outlined"
							  Adornment="Adornment.Start"
							  AdornmentIcon="@Icons.Material.Filled.Search"
							  IconSize="Size.Small"
							  DebounceInterval="300"
							  Immediate="true"
							  Class="mt-0" />
			</ToolBarContent>

			<!-- Cabeçalho da tabela -->
			<HeaderContent>
				<MudTh><MudTableSortLabel SortBy="new Func<UserDto, object>(x => x.Name)">Nome</MudTableSortLabel></MudTh>
				<MudTh><MudTableSortLabel SortBy="new Func<UserDto, object>(x => x.Email)">Email</MudTableSortLabel></MudTh>
				<MudTh><MudTableSortLabel SortBy="new Func<UserDto, object>(x => x.Role)">Perfil</MudTableSortLabel></MudTh>
				<MudTh Style="width: 120px; text-align: center;">Ações</MudTh>
			</HeaderContent>

			<!-- Linhas da tabela -->
			<RowTemplate>
				<MudTd DataLabel="Nome">@context.Name</MudTd>
				<MudTd DataLabel="Email">@context.Email</MudTd>
				<MudTd DataLabel="Perfil">@context.Role</MudTd>
				<MudTd DataLabel="Ações" Style="text-align: center;">
					<MudStack Row="true" Spacing="1" Justify="Justify.Center">
						@if (context.Active)
						{
							<!-- Botão Alterar -->
							<MudTooltip Text="Alterar">
								<MudIconButton Icon="@Icons.Material.Filled.Edit"
											   Color="Color.Primary"
											   Size="Size.Small"
											   OnClick="@(async () => await OnShowModalEditClick(context))" />
							</MudTooltip>

							<!-- Botão Desativar -->
							<MudTooltip Text="Desativar">
								<MudIconButton Icon="@Icons.Material.Filled.Delete"
											   Color="Color.Error"
											   Size="Size.Small"
											   OnClick="@(async () => await OnShowModalDeleteClick(context))" />
							</MudTooltip>
						}
						else
						{
							<!-- Botão Reativar -->
							<MudTooltip Text="Reativar">
								<MudIconButton Icon="@Icons.Material.Filled.Refresh"
											   Color="Color.Info"
											   Size="Size.Small"
											   OnClick="@(async () => await OnShowModalReactiveClick(context))" />
							</MudTooltip>
						}
					</MudStack>
				</MudTd>
			</RowTemplate>

			<!-- Paginação -->
			<PagerContent>
				<MudTablePager PageSizeOptions="new int[] { 5, 10, 25, 50 }" />
			</PagerContent>

			<!-- Mensagem quando não há dados -->
			<NoRecordsContent>
				<MudText Align="Align.Center">Nenhum usuário encontrado</MudText>
			</NoRecordsContent>

			<!-- Loading indicator -->
			<LoadingContent>
				<MudText Align="Align.Center">Carregando...</MudText>
			</LoadingContent>
		</MudTable>


	</div>

</div>

<br />

@code {

	[Inject]
	public ISnackbar SnackbarService { get; set; } = null!;

	private MudTable<UserDto> gridUser = new();
	private List<UserDto> users = new();
	private string searchString = "";
	private bool loading = false;

	//RadzenDataGrid<UserDto> gridUser;
	private BlazorBootstrap.Button editUserButton = default!;
	private BlazorBootstrap.Button findCepUserButton = default!;

	private RadzenMask zipMask = default!;
	private readonly UserSessionInformation _userSessionInformation;

	//RadzenDataGrid<UserDto> gridUser;


	UserEntity user = new UserEntity();
	List<UserDto> usersDto = new List<UserDto>();

	bool allowRowSelectOnRowClick = true;

	private Modal modalScreen = default!;
	private Modal modalDeactiveReactive = default!;
	//private Grid<UserDto> gridUser = default!;



	bool insertMode = false;
	bool deactiveMode = false;
	string modalTitle = string.Empty;

	List<ToastMessage> messages = new List<ToastMessage>();

	protected override async Task OnInitializedAsync()
	{
		await LoadManufactures();
	}

	async Task LoadManufactures()
	{
		usersDto = await GetUsersDtoAsync();
	}


	private async Task<GridDataProviderResult<UserDto>> UserDtoDataProvider(GridDataProviderRequest<UserDto> request)
	{
		var usersDto = await GetUsersDtoAsync();

		return await Task.FromResult(request.ApplyTo(usersDto));
	}

	private async Task ExecuteAction(Func<Task<bool>> action, string successMessage)
	{
		try
		{
			if (await action())
			{
				Snackbar.Add(successMessage, Severity.Success);
				await ReloadGrid();
			}
			else
			{
				Snackbar.Add("Erro na operação", Severity.Error);
			}
		}
		catch (Exception ex)
		{
			Snackbar.Add(ex.Message, Severity.Error);
		}
	}


	private async Task<List<UserDto>> GetUsersDtoAsync()
	{
		var usersEntity = await _userService.GetUserAllAsync();

		return usersEntity.Select(x => new UserDto()
		{
			Uuid = x.Uuid,
			Name = x.Name,
			Email = x.Email,

			Active = x.Active,
			Role = x.Role.ToString(),
		}).ToList();
	}

	private bool FilterUsers(UserDto user)
	{
		if (string.IsNullOrWhiteSpace(searchString))
			return true;

		return user.Name?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true ||
						user.Email?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true ||
						user.Role?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true;
	}

	#region	Ons
	private async Task OnFindCepClick()
	{
		if (!string.IsNullOrEmpty(user?.Address?.ZipCode))
		{
			var address = await _externalService.GetAddressCep(user.Address.ZipCode);

			user.Address.City = address.Localidade;

			user.Address.Neighborhood = address.Bairro;
			user.Address.Complement = address.Complemento;
			user.Address.State = address.Uf; //Enum.Parse<UfType>(address.Uf).ToString();
			user.Address.Street = address.Logradouro;
			user.Address.ZipCode = address.Cep;
		}
		else
		{
			ExibirMensagem("Cep invalido.", Severity.Error);
			await zipMask.FocusAsync();
		}
	}

	private async Task OnShowModalInsertClick()
	{
		user = new UserEntity()
		{
			Name = string.Empty,
			Password = string.Empty,
			Address = new AddressEntity()
		};

		insertMode = true;
		modalTitle = "Adicionar usuário";

		await modalScreen.ShowAsync();
	}

	private async Task OnPersisteModalUser()
	{
		if (insertMode)
			await OnIncludeUser();
		else
			await OnUpdateUser();

		insertMode = false;
		modalTitle = string.Empty;

		await OnHideModalInsertClick();
	}


	private async Task OnPersisteDeleteModalUser()
	{
		if (deactiveMode)
			await OnDeactiveUser();
		else
			await OnReactiveUser();

		deactiveMode = false;
		modalTitle = string.Empty;

		await OnHideModalDeactiveClick();
	}

	private async Task OnUpdateUser()
	{
		await ExecuteAction(
			() => _userService.EditAsync(user),
			"Usuário atualizado com sucesso"
		);
	}

	private async Task OnDeactiveUser()
	{
		await ExecuteAction(
			() => _userService.DeactiveAsync(user),
			"Usuário desativado com sucesso"
		);
	}

	private async Task OnReactiveUser()
	{
		await ExecuteAction(
			() => _userService.ReactiveAsync(user),
			"Usuário reativado com sucesso"
		);
	}

	private async Task ReloadGrid()
	{
		//usersDto = await GetUsersDtoAsync();

		// // Limpa qualquer item em edição
		// gridUser.SetEditingItem(null);
            
		// // Recarrega os dados na grid
		// await gridUser.ReloadServerData();
            
		// // Força a atualização da UI
		// StateHasChanged();
		loading = true;

		usersDto = await GetUsersDtoAsync();

		loading = false;

		StateHasChanged();
	}
	


	private async Task OnIncludeUser()
	{
		await ExecuteAction(
			() => _userService.AddAsync(user),
			"Usuário criado com sucesso"
		);
	}

	private async Task OnHideModalInsertClick()
	{
		await modalScreen.HideAsync();
	}

	private async Task OnHideModalDeactiveClick()
	{
		await modalDeactiveReactive.HideAsync();
	}

	private async Task OnShowModalEditClick(UserDto data)
	{
		insertMode = false;
		modalTitle = "Alterar usuário";

		var responseUser = await _userService.GetUserByUuidAsync(data.Uuid);

		if (responseUser == null || string.IsNullOrEmpty(responseUser.Name))
			ExibirMensagem("Error ao recuperar usuário.", Severity.Error);

		user = responseUser;

		//await modalUpdate.ShowAsync();
		await modalScreen.ShowAsync();
	}

	private async Task OnShowModalDeleteClick(UserDto data)
	{
		deactiveMode = true;
		modalTitle = "Desativação de usuário";

		var responseUser = await _userService.GetUserByUuidAsync(data.Uuid);

		if (responseUser == null || string.IsNullOrEmpty(responseUser.Name))
			ExibirMensagem("Error ao recuperar usuário.", Severity.Error);

		user = responseUser;

		//await modalUpdate.ShowAsync();
		await modalDeactiveReactive.ShowAsync();
	}

	private async Task OnShowModalReactiveClick(UserDto data)
	{
		deactiveMode = false;
		modalTitle = "Reativação de usuário";

		var responseUser = await _userService.GetUserByUuidAsync(data.Uuid);

		if (responseUser == null || string.IsNullOrEmpty(responseUser.Name))
			ExibirMensagem("Error ao recuperar usuário.", Severity.Error);

		user = responseUser;

		//await modalUpdate.ShowAsync();
		await modalDeactiveReactive.ShowAsync();
	}

	private async Task OnHideModalEditClick()
	{
		await modalScreen.HideAsync();
	}
	#endregion


	private void ExibirMensagem(string mensagem, Severity serverity = Severity.Error)
	{
		var config = (SnackbarOptions options) =>
		{
			options.DuplicatesBehavior = SnackbarDuplicatesBehavior.Prevent;
		};

		SnackbarService.Add(mensagem, serverity, configure: config, key: "User");
	}

}