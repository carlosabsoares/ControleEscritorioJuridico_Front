@page "/users"
@page "/users/Index"
@using CEJ_WebApp.Components.Users
@using CEJ_WebApp.Core.Services
@using CEJ_WebApp.Model
@using CEJ_WebApp.Model.Dto
@using CEJ_WebApp.Model.Enum
@using CEJ_WebApp.Components.Client

@inject IUserService _userService
@inject IExternalService _externalService
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject NotificationService Notification

<MudPaper Class="pa-6" Elevation="2" Style="border-radius: 12px;">

	<MudStack Row="true"
			  Justify="Justify.SpaceBetween"
			  AlignItems="AlignItems.Center"
			  Class="mb-4">

		<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
			<MudIcon Icon="@Icons.Material.Filled.People"
					 Size="Size.Large"
					 Color="Color.Primary" />
			<MudText Typo="Typo.h5" Style="font-weight: 500;">Usuários</MudText>
		</MudStack>


		<MudFab Color="Color.Primary"
				StartIcon="@Icons.Material.Filled.Add"
				Size="Size.Medium"
				title="Adicionar um usuário"
				OnClick="OpenModalAsync" />
	</MudStack>

	<MudTable @ref="gridUser"
			  T="UserDto"
			  Items="@usersDto"
			  Filter="new Func<UserDto, bool>(FilterUsers)"
			  FilterMode="FilterMode.Filterable"
			  FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive"
			  Hover="true"
			  Bordered="true"
			  Striped="true"
			  Dense="true"
			  Loading="@loading"
			  Breakpoint="Breakpoint.Xs"
			  Height="auto"
			  FixedHeader="false"
			  HorizontalScrollbar="true"
			  Style="width:100%; overflow-x:auto; border-radius: 8px;">

		<!-- Toolbar -->
		<ToolBarContent>
			<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="pa-2">
				<MudIcon Icon="@Icons.Material.Filled.FormatListBulleted"
						 Size="Size.Small"
						 Color="Color.Default" />
				<MudText Typo="Typo.subtitle2" Color="Color.Default">Lista de Usuários</MudText>
				<MudSpacer />
        
				<MudTextField @bind-Value="searchString"
							  Placeholder="Pesquisar por nome, email ou telefone..."
							  Variant="Variant.Outlined"
							  Adornment="Adornment.Start"
							  AdornmentIcon="@Icons.Material.Filled.Search"
							  IconSize="Size.Small"
							  DebounceInterval="300"
							  Immediate="true"
							  Style="min-width: 300px; max-width: 600px; width: 100%;" />
			</MudStack>
		</ToolBarContent>

		<!-- Header -->
		<HeaderContent>
			<MudTh><MudTableSortLabel SortBy="new Func<UserDto, object>(x => x.Name)">Nome</MudTableSortLabel></MudTh>
			<MudTh><MudTableSortLabel SortBy="new Func<UserDto, object>(x => x.Email)">Email</MudTableSortLabel></MudTh>
			<MudTh><MudTableSortLabel SortBy="new Func<UserDto, object>(x => x.Role)">Perfil</MudTableSortLabel></MudTh>
			<MudTh Style="width: 120px; text-align: center;">Ações</MudTh>
		</HeaderContent>


		<!-- Rows -->
		<RowTemplate>
			<MudTd DataLabel="Nome">@context.Name</MudTd>
			<MudTd DataLabel="Email">@context.Email</MudTd>
			<MudTd DataLabel="Perfil">@context.Role</MudTd>
			<MudTd DataLabel="Ações" Style="text-align: center;">
				<MudStack Row="true" Spacing="1" Justify="Justify.Center">
					@if (context.Active)
					{
						<!-- Botão Alterar -->
						<MudTooltip Text="Alterar">
							<MudIconButton Icon="@Icons.Material.Filled.Edit"
										   Color="Color.Primary"
										   Size="Size.Small"
										   OnClick="@(async () => await OnShowModalEditClick(context))" />
						</MudTooltip>

						<!-- Botão Desativar -->
						<MudTooltip Text="Desativar">
							<MudIconButton Icon="@Icons.Material.Filled.Delete"
										   Color="Color.Error"
										   Size="Size.Small"
										   OnClick="@(async () => await OnShowModalDeleteClick(context))" />
						</MudTooltip>
					}
					else
					{
						<!-- Botão Reativar -->
						<MudTooltip Text="Reativar">
							<MudIconButton Icon="@Icons.Material.Filled.Refresh"
										   Color="Color.Info"
										   Size="Size.Small"
										   OnClick="@(async () => await OnShowModalReactiveClick(context))" />
						</MudTooltip>
					}
				</MudStack>
			</MudTd>
		</RowTemplate>

		<!-- Pager -->
		<PagerContent>
			<div class="pa-2">
				<MudTooltip Text="Alterar quantidade de itens por página" Placement="MudBlazor.Placement.Top">
					<MudTablePager PageSizeOptions="new int[] { 5, 10, 25, 50, 100 }" />
				</MudTooltip>
			</div>
		</PagerContent>

		<!-- Empty -->
		<NoRecordsContent>
			<MudPaper Class="pa-8 text-center" Elevation="0">
				<MudIcon Icon="@Icons.Material.Filled.PeopleOutline"
						 Size="Size.Large"
						 Color="Color.Default"
						 Style="opacity: 0.5;" />
				<MudText Typo="Typo.body1" Class="mt-2" Color="Color.Default">
					Nenhum usuário encontrado
				</MudText>
				<MudText Typo="Typo.body2" Color="Color.Default" Style="opacity: 0.7;">
					Clique no botão + para adicionar um novo usuário
				</MudText>
			</MudPaper>
		</NoRecordsContent>

		<!-- Loading -->
		<LoadingContent>
			<div class="d-flex justify-center align-center pa-6">
				<MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Medium" />
				<MudText Class="ml-3" Color="Color.Default">Carregando usuários...</MudText>
			</div>
		</LoadingContent>

	</MudTable>

</MudPaper>

@code {
	[Inject]
	public ISnackbar SnackbarService { get; set; } = null!;

	private MudTable<UserDto> gridUser = new();
	private List<UserDto> usersDto = new();
	private string searchString = "";
	private bool loading = false;

	private bool _dialogOpen = false;

	private ClientActiveDeactiveModal clientActiveDeactiveModal = default!;
	private bool insertMode = false;
	private bool deactiveMode = false;
	private string modalTitle = string.Empty;

	ClientEntity client = new ClientEntity();

	protected override async Task OnInitializedAsync()
	{
		await LoadManufactures();
	}

	async Task LoadManufactures()
	{
		try
		{
			loading = true;

			var task = GetUsersDtoAsync();

			await Task.WhenAll(task, Task.Delay(300));

			usersDto = task.Result;
		}
		finally
		{
			loading = false;
		}
	}

	private bool FilterUsers(UserDto user)
	{
		if (string.IsNullOrWhiteSpace(searchString))
			return true;

		return user.Name?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true ||
						user.Email?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true ||
						user.Role?.Contains(searchString, StringComparison.OrdinalIgnoreCase) == true;
	}

	private async Task OnShowModalEditClick(UserDto data)
	{
		if (_dialogOpen) return;

		_dialogOpen = true;

		try
		{
			var user = await _userService.GetUserByUuidAsync(data.Uuid);

			if (user == null || string.IsNullOrEmpty(user.Name))
				Notification.ExibirMensagem("Erro ao recuperar Usuário.", Severity.Error);

			var parameters = new DialogParameters
			{
				{ "User", user },
				{ "InsertMode", false }
			};

			var options = new DialogOptions
			{
				CloseOnEscapeKey = true,
				MaxWidth = MaxWidth.Large,
				FullWidth = true,
				CloseButton = true
			};

			// var dialog = await DialogService.ShowAsync<UserDialog>("", parameters, options);
			// var result = await dialog.Result;

			// if (!result.Canceled)
			// 	await ReloadGrid();
		}
		finally
		{
			_dialogOpen = false;
		}
	}

	private async Task OnShowModalReactiveClick(UserDto data)
	{
		var responseUser = await _userService.GetUserByUuidAsync(data.Uuid);

		if (responseUser == null || string.IsNullOrEmpty(responseUser.Name))
		{
			Notification.ExibirMensagem("Erro ao recuperar usuário.", Severity.Error);
			return;
		}

		var parameters = new DialogParameters{
			{ "User", responseUser },
			{ "DeactiveMode", false }
		};

		var options = new DialogOptions
		{
			MaxWidth = MaxWidth.Small,
			FullWidth = true,
			CloseOnEscapeKey = true,
			CloseButton = true
		};

		// var dialog = await DialogService.ShowAsync<ClientActiveDeactiveDialog>(
		// 	"Reativar Usuário",
		// 	parameters,
		// 	options
		// );

		// var result = await dialog.Result;

		// if (!result.Canceled)
		// 	await ReloadGrid();
	}

	private async Task OnShowModalDeleteClick(UserDto data)
	{
		var responseUser = await _userService.GetUserByUuidAsync(data.Uuid);

		if (responseUser == null || string.IsNullOrEmpty(responseUser.Name))
		{
			Notification.ExibirMensagem("Erro ao recuperar usuário.", Severity.Error);
			return;
		}

		var parameters = new DialogParameters{
			{ "User", responseUser },
			{ "DeactiveMode", true }
		};

		var options = new DialogOptions
		{
			MaxWidth = MaxWidth.Small,
			FullWidth = true,
			CloseOnEscapeKey = true,
			CloseButton = true
		};

		// var dialog = await DialogService.ShowAsync<ClientActiveDeactiveDialog>(
		// 	"Desativar Cliente",
		// 	parameters,
		// 	options
		// );

		// var result = await dialog.Result;

		// if (!result.Canceled)
		// 	await ReloadGrid();
	}

	private async Task ReloadGrid()
	{
		try
		{
			loading = true;

			await LoadManufactures();
			await gridUser.ReloadServerData();
		}
		finally
		{
			loading = false;
		}
	}

	private async Task OnShowOffClick()
	{
		Notification.ExibirMensagem("Funcionalidade em desenvolvimento", Severity.Info);
	}

	private async Task<List<UserDto>> GetUsersDtoAsync()
	{
		var userEntity = await _userService.GetUserAllAsync();

		return userEntity.Select(x => new UserDto()
		{
			Uuid = x.Uuid,
			Name = x.Name,
			Email = x.Email,
			Active = x.Active,
            Role = x.Role.ToString()
		}).ToList();
	}

	private async Task OpenModalAsync()
	{
		if (_dialogOpen) return;

		_dialogOpen = true;

		try
		{
			var user = new UserEntity()
			{
				Name = string.Empty,
				Role = UserRoleType.Nenhum,
				Address = new AddressEntity()
			};

			var parameters = new DialogParameters
			{
				{ "User", user },
				{ "InsertMode", true }
			};

			var options = new DialogOptions
			{
				CloseOnEscapeKey = true,
				MaxWidth = MaxWidth.Large,
				FullWidth = true,
				CloseButton = true
			};

			var dialog = await DialogService.ShowAsync<UserDialog>("", parameters, options);
			var result = await dialog.Result;

			if (!result.Canceled)
				await ReloadGrid();
		}
		finally
		{
			_dialogOpen = false;
		}
	}
}