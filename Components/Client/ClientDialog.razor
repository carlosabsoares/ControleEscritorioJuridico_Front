@* @using CEJ_WebApp.Core.Services
@using CEJ_WebApp.Model
@using CEJ_WebApp.Model.Enum
@using MudBlazor
@inject IExternalService _externalService
@inject IClientService _clientService
@inject NotificationService Notification

<MudDialog MaxWidth="MaxWidth.Large" FullWidth="true">

    <DialogContent>

        <MudPaper Class="pa-4 mb-4" Elevation="0" Style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 12px;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@(InsertMode ? Icons.Material.Filled.PersonAdd : Icons.Material.Filled.Edit)" 
                         Size="Size.Large" 
                         Color="Color.Inherit" 
                         Style="color: white;" />
                <MudText Typo="Typo.h5" Style="color: white; font-weight: 500;">
                    @(InsertMode ? "Novo Cliente" : "Editar Cliente")
                </MudText>
            </MudStack>
        </MudPaper>

        <EditForm Model="@Client">
            <DataAnnotationsValidator />

            <!-- Nome + Documento -->
            <MudGrid>
                <MudItem xs="12" md="5">
                    <MudTooltip Text="Nome completo do cliente" Placement="MudBlazor.Placement.Top">
                        <MudTextField @bind-Value="@Client.Name" 
                                      Label="Nome" 
                                      Variant="Variant.Outlined" 
                                      Margin="Margin.Dense" 
                                      FullWidth="true" 
                                      AdornmentIcon="@Icons.Material.Filled.Person"
                                      Adornment="Adornment.Start" />
                    </MudTooltip>
                </MudItem>

                <MudItem xs="12" md="3">
                    <MudTooltip Text="Selecione o tipo de documento" Placement="MudBlazor.Placement.Top">
                        <MudSelect T="DocumentType"
                                   Label="Tipo de Documento"
                                   Value="Client.DocumentType"
                                   ValueChanged="OnDocumentTypeChanged"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   FullWidth="true"
                                   AdornmentIcon="@Icons.Material.Filled.Description"
                                   Adornment="Adornment.Start">
                            @foreach (var documentType in Enum.GetValues<DocumentType>())
                            {
                                <MudSelectItem Value="@documentType">@documentType</MudSelectItem>
                            }
                        </MudSelect>
                    </MudTooltip>
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudTooltip Text="Digite o número do documento conforme o tipo selecionado" Placement="MudBlazor.Placement.Top">
                        <MudMask T="string"
                                 @key="documentMaskKey"
                                 Label="Número do Documento"
                                 Mask="@documentMask"
                                 @bind-Value="Client.DocumentNumber"
                                 Variant="Variant.Outlined"
                                 Margin="Margin.Dense"
                                 FullWidth="true"
                                 AdornmentIcon="@Icons.Material.Filled.Badge"
                                 Adornment="Adornment.Start" />
                    </MudTooltip>
                </MudItem>
            </MudGrid>

            <!-- Email + extras -->
            <MudGrid Class="mt-2">
                <MudItem xs="12" md="4">
                    <MudTooltip Text="E-mail para contato" Placement="MudBlazor.Placement.Top">
                        <MudTextField @bind-Value="@Client.Email" 
                                      Label="Email" 
                                      Variant="Variant.Outlined" 
                                      Margin="Margin.Dense" 
                                      FullWidth="true"
                                      AdornmentIcon="@Icons.Material.Filled.Email"
                                      Adornment="Adornment.Start" />
                    </MudTooltip>
                </MudItem>

                @if (isNaturalPerson)
                {
                    <MudItem xs="12" md="4">
                        <MudTooltip Text="Registro Geral (RG)" Placement="MudBlazor.Placement.Top">
                            <MudTextField @bind-Value="@Client.GeneralRegister" 
                                          Label="RG" 
                                          Variant="Variant.Outlined" 
                                          Margin="Margin.Dense" 
                                          FullWidth="true"
                                          AdornmentIcon="@Icons.Material.Filled.CreditCard"
                                          Adornment="Adornment.Start" />
                        </MudTooltip>
                    </MudItem>

                    <MudItem xs="12" md="4">
                        <MudTooltip Text="Profissão do cliente" Placement="MudBlazor.Placement.Top">
                            <MudTextField @bind-Value="@Client.Profession" 
                                          Label="Profissão" 
                                          Variant="Variant.Outlined" 
                                          Margin="Margin.Dense" 
                                          FullWidth="true"
                                          AdornmentIcon="@Icons.Material.Filled.Work"
                                          Adornment="Adornment.Start" />
                        </MudTooltip>
                    </MudItem>
                }
            </MudGrid>

            <!-- Telefones -->
            <MudGrid Class="mt-2">
                <MudItem xs="12" md="4">
                    <MudTooltip Text="Telefone fixo para contato" Placement="MudBlazor.Placement.Top">
                        <MudTextField @bind-Value="@Client.PhoneNumber"
                                      Label="Telefone"
                                      Mask="@(new PatternMask("(00) 0000-0000"))"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      FullWidth="true"
                                      AdornmentIcon="@Icons.Material.Filled.Phone"
                                      Adornment="Adornment.Start" />
                    </MudTooltip>
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudTooltip Text="Celular para contato (WhatsApp)" Placement="MudBlazor.Placement.Top">
                        <MudTextField @bind-Value="@Client.CellPhoneNumber"
                                      Label="Celular"
                                      Mask="@(new PatternMask("(00) 00000-0000"))"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      FullWidth="true"
                                      AdornmentIcon="@Icons.Material.Filled.Smartphone"
                                      Adornment="Adornment.Start" />
                    </MudTooltip>
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudTooltip Text="Nome do contato de referência" Placement="MudBlazor.Placement.Top">
                        <MudTextField @bind-Value="@Client.ContactName"
                                      Label="Contato"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      FullWidth="true"
                                      AdornmentIcon="@Icons.Material.Filled.ContactMail"
                                      Adornment="Adornment.Start" />
                    </MudTooltip>
                </MudItem>
            </MudGrid>

            <!-- Endereço -->
            <MudPaper Class="pa-4 mt-4" Elevation="1" Style="border-radius: 8px; border: 1px solid #e0e0e0;">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mb-3">
                    <MudIcon Icon="@Icons.Material.Filled.LocationOn" Color="Color.Primary" Size="Size.Small" />
                    <MudText Typo="Typo.h6">Endereço</MudText>
                </MudStack>

                <MudGrid>
                    <MudItem xs="12" md="6">
                        <MudTooltip Text="Digite o CEP e clique na lupa para buscar automaticamente" Placement="MudBlazor.Placement.Top">
                            <MudMask T="string"
                                     Label="CEP"
                                     Mask="@(new PatternMask("00000-000"))"
                                     @bind-Value="Client.Address.ZipCode"
                                     Variant="Variant.Outlined"
                                     FullWidth="true"
                                     Adornment="Adornment.End"
                                     AdornmentIcon="@Icons.Material.Filled.Search"
                                     OnAdornmentClick="OnFindCepClick"
                                     AdornmentColor="Color.Primary" />
                        </MudTooltip>
                    </MudItem>
                </MudGrid>

                <MudGrid Class="mt-2">
                    <MudItem xs="12" md="5">
                        <MudTooltip Text="Logradouro / Rua" Placement="MudBlazor.Placement.Top">
                            <MudTextField @bind-Value="@Client.Address.Street" 
                                          Label="Logradouro" 
                                          Variant="Variant.Outlined" 
                                          Margin="Margin.Dense" 
                                          FullWidth="true"
                                          AdornmentIcon="@Icons.Material.Filled.Home"
                                          Adornment="Adornment.Start" />
                        </MudTooltip>
                    </MudItem>

                    <MudItem xs="12" md="2">
                        <MudTooltip Text="Número do endereço" Placement="MudBlazor.Placement.Top">
                            <MudTextField @bind-Value="@Client.Address.Number" 
                                          Label="Número" 
                                          Variant="Variant.Outlined" 
                                          Margin="Margin.Dense" 
                                          FullWidth="true" />
                        </MudTooltip>
                    </MudItem>

                    <MudItem xs="12" md="5">
                        <MudTooltip Text="Complemento (apto, sala, bloco, etc)" Placement="MudBlazor.Placement.Top">
                            <MudTextField @bind-Value="@Client.Address.Complement" 
                                          Label="Complemento" 
                                          Variant="Variant.Outlined" 
                                          Margin="Margin.Dense" 
                                          FullWidth="true" />
                        </MudTooltip>
                    </MudItem>
                </MudGrid>

                <MudGrid Class="mt-2">
                    <MudItem xs="12" md="5">
                        <MudTooltip Text="Bairro" Placement="MudBlazor.Placement.Top">
                            <MudTextField @bind-Value="@Client.Address.Neighborhood" 
                                          Label="Bairro" 
                                          Variant="Variant.Outlined" 
                                          Margin="Margin.Dense" 
                                          FullWidth="true"
                                          AdornmentIcon="@Icons.Material.Filled.Apartment"
                                          Adornment="Adornment.Start" />
                        </MudTooltip>
                    </MudItem>

                    <MudItem xs="12" md="5">
                        <MudTooltip Text="Cidade" Placement="MudBlazor.Placement.Top">
                            <MudTextField @bind-Value="@Client.Address.City" 
                                          Label="Cidade" 
                                          Variant="Variant.Outlined" 
                                          Margin="Margin.Dense" 
                                          FullWidth="true"
                                          AdornmentIcon="@Icons.Material.Filled.LocationCity"
                                          Adornment="Adornment.Start" />
                        </MudTooltip>
                    </MudItem>

                    <MudItem xs="12" md="2">
                        <MudTooltip Text="Estado (UF)" Placement="MudBlazor.Placement.Top">
                            <MudSelect T="string"
                                       Label="Estado"
                                       @bind-Value="Client.Address.State"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense"
                                       FullWidth="true"
                                       AdornmentIcon="@Icons.Material.Filled.Map"
                                       Adornment="Adornment.Start">
                                @foreach (var uf in Enum.GetValues<UfType>())
                                {
                                    <MudSelectItem Value="@uf.ToString()">@uf</MudSelectItem>
                                }
                            </MudSelect>
                        </MudTooltip>
                    </MudItem>
                </MudGrid>

            </MudPaper>

        </EditForm>

    </DialogContent>

    <DialogActions>
        <MudTooltip Text="Fechar sem salvar" Placement="MudBlazor.Placement.Top">
            <MudButton Color="Color.Secondary" 
                       OnClick="Cancel"
                       Variant="Variant.Outlined">
                Fechar
            </MudButton>
        </MudTooltip>

        <MudTooltip Text="@(InsertMode ? "Adicionar novo cliente" : "Salvar alterações")" Placement="MudBlazor.Placement.Top">
            <MudButton Color="Color.Primary" 
                       OnClick="Salvar"
                       Variant="Variant.Filled"
                       StartIcon="@Icons.Material.Filled.Save">
                Salvar
            </MudButton>
        </MudTooltip>
    </DialogActions>

</MudDialog>

@code {

    [CascadingParameter]
    MudDialogInstance MudDialog { get; set; }

    [Parameter] public ClientEntity Client { get; set; }
    [Parameter] public bool InsertMode { get; set; }

    private IMask documentMask = new PatternMask("000.000.000-00");
    private string documentMaskKey = "cpf";
    private bool isNaturalPerson = false;

    private async Task Salvar()
    {
        bool result;

        if (InsertMode)
            result = await _clientService.AddAsync(Client);
        else
            result = await _clientService.EditAsync(Client);

        if (result)
            Notification.ExibirMensagem("Sucesso!", Severity.Success);
        else
            Notification.ExibirMensagem("Erro!", Severity.Error);

        MudDialog.Close(DialogResult.Ok(true));
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private void OnDocumentTypeChanged(DocumentType type)
    {
        Client.DocumentType = type;

        if (type == DocumentType.CNPJ)
        {
            documentMask = new PatternMask("00.000.000/0000-00");
            documentMaskKey = "cnpj";
            isNaturalPerson = false;
        }
        else
        {
            documentMask = new PatternMask("000.000.000-00");
            documentMaskKey = "cpf";
            isNaturalPerson = true;
        }

        Client.DocumentNumber = string.Empty;
    }

    private async Task OnFindCepClick()
    {
        var address = await _externalService.GetAddressCep(Client.Address.ZipCode);

        Client.Address.City = address.Localidade;
        Client.Address.Neighborhood = address.Bairro;
        Client.Address.State = address.Uf;
        Client.Address.Street = address.Logradouro;
    }
} *@

@using CEJ_WebApp.Core.Services
