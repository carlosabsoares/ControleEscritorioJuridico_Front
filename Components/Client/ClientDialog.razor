@using CEJ_WebApp.Core.Services
@using CEJ_WebApp.Model
@using CEJ_WebApp.Model.Enum
@using MudBlazor

@inject IClientService _clientService
@inject NotificationService Notification

<MudDialog MaxWidth="MaxWidth.Large" FullWidth="true">

    <DialogContent>

        <MudPaper Class="pa-4 mb-4" Elevation="0" Style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 12px;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@(InsertMode ? Icons.Material.Filled.PersonAdd : Icons.Material.Filled.Edit)"
                         Size="Size.Large"
                         Color="Color.Inherit"
                         Style="color: white;" />
                <MudText Typo="Typo.h5" Style="color: white; font-weight: 500;">
                    @(InsertMode ? "Novo Cliente" : "Editar Cliente")
                </MudText>
            </MudStack>
        </MudPaper>

        <EditForm Model="@Client">
            <DataAnnotationsValidator />

            <MudGrid>

                <MudItem xs="12" md="5">
                    <MudTextField @bind-Value="@Client.Name"
                                  Label="Nome"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  FullWidth="true"
                                  AdornmentIcon="@Icons.Material.Filled.Person"
                                  Adornment="Adornment.Start" />
                </MudItem>

                <MudItem xs="12" md="3">
                    <MudSelect T="DocumentType"
                               Label="Tipo de Documento"
                               Value="Client.DocumentType"
                               ValueChanged="OnDocumentTypeChanged"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               FullWidth="true"
                               AdornmentIcon="@Icons.Material.Filled.Description"
                               Adornment="Adornment.Start">
                        @foreach (var documentType in Enum.GetValues<DocumentType>())
                        {
                            <MudSelectItem Value="@documentType">@documentType</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudTextField T="string"
                                  Label="Documento"
                                  Value="_displayDocumentNumber"
                                  ValueChanged="OnDocumentDisplayChanged"
                                  FullWidth="true"
                                  Immediate="true"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  TextUpdateSuppression="false"
                                  AdornmentIcon="@Icons.Material.Filled.Description"
                                  Adornment="Adornment.Start" />
                </MudItem>

            </MudGrid>

            <MudGrid Class="mt-2">

                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="@Client.Email"
                                  Label="Email"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  FullWidth="true"
                                  AdornmentIcon="@Icons.Material.Filled.Email"
                                  Adornment="Adornment.Start" />
                </MudItem>

                @if (isNaturalPerson)
                {
                    <MudItem xs="12" md="4">
                        <MudTextField @bind-Value="@Client.GeneralRegister"
                                      Label="RG"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      FullWidth="true"
                                      AdornmentIcon="@Icons.Material.Filled.CreditCard"
                                      Adornment="Adornment.Start" />
                    </MudItem>

                    <MudItem xs="12" md="4">
                        <MudTextField @bind-Value="@Client.Profession"
                                      Label="Profissão"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      FullWidth="true"
                                      AdornmentIcon="@Icons.Material.Filled.Work"
                                      Adornment="Adornment.Start" />
                    </MudItem>
                }

            </MudGrid>

            <MudGrid Class="mt-2">

                <MudItem xs="12" md="4">
                    <MudTextField Value="@Client.PhoneNumber"
                                  ValueChanged="@((string v) => Client.PhoneNumber = ApplyPhoneMask(v))"
                                  Label="Telefone"
                                  FullWidth="true"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  AdornmentIcon="@Icons.Material.Filled.Phone"
                                  Adornment="Adornment.Start"
                                  MaxLength="14"
                                  Immediate="true" />
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudTextField Value="@Client.CellPhoneNumber"
                                  ValueChanged="@((string v) => Client.CellPhoneNumber = ApplyCellPhoneMask(v))"
                                  Label="Celular"
                                  FullWidth="true"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Immediate="true"
                                  AdornmentIcon="@Icons.Material.Filled.Smartphone"
                                  MaxLength="15"
                                  Adornment="Adornment.Start" />
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="@Client.ContactName"
                                  Label="Contato"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  FullWidth="true"
                                  AdornmentIcon="@Icons.Material.Filled.ContactMail"
                                  Adornment="Adornment.Start" />
                </MudItem>

            </MudGrid>

            <MudDivider Class="my-3" />

            <!-- ✅ NOVO COMPONENTE -->
            <AddressForm Address="Client.Address" />

        </EditForm>

    </DialogContent>

    <DialogActions>
        <MudButton Color="Color.Secondary"
                   OnClick="Cancel"
                   Variant="Variant.Outlined">
            Fechar
        </MudButton>
        <MudButton Color="Color.Primary"
                   OnClick="Salvar"
                   Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Save">
            Salvar
        </MudButton>
    </DialogActions>

</MudDialog>

@code {

    [CascadingParameter] MudDialogInstance MudDialog { get; set; }

    [Parameter] public ClientEntity Client { get; set; }
    [Parameter] public bool InsertMode { get; set; }

    private bool isNaturalPerson = true;
    private string _displayDocumentNumber = string.Empty;

    protected override void OnInitialized()
    {
        if (Client == null)
            Client = new ClientEntity();

        if (Client.Address == null)
            Client.Address = new AddressEntity();

        _displayDocumentNumber = FormatDocumentForDisplay(Client.DocumentNumber, Client.DocumentType);
    }

    private string FormatDocumentForDisplay(string documentNumber, DocumentType documentType)
    {
        if (string.IsNullOrEmpty(documentNumber))
            return string.Empty;

        return ApplyDocumentMask(documentNumber, documentType);
    }

    private void OnDocumentDisplayChanged(string value)
    {
        if (string.IsNullOrEmpty(value))
        {
            _displayDocumentNumber = string.Empty;
            Client.DocumentNumber = string.Empty;
            return;
        }

        var cleanValue = new string(value.Where(char.IsDigit).ToArray());
        _displayDocumentNumber = ApplyDocumentMask(cleanValue, Client.DocumentType);
        Client.DocumentNumber = cleanValue;
    }

    private void OnDocumentTypeChanged(DocumentType type)
    {
        Client.DocumentType = type;
        Client.DocumentNumber = string.Empty;
        _displayDocumentNumber = string.Empty;
        isNaturalPerson = type != DocumentType.CNPJ;
    }

    private string ApplyDocumentMask(string value, DocumentType documentType)
    {
        return documentType switch
        {
            DocumentType.CPF => ApplyCpfMask(value),
            DocumentType.CNPJ => ApplyCnpjMask(value),
            _ => value
        };
    }

    private string ApplyCpfMask(string cpf)
    {
        cpf = new string(cpf.Where(char.IsDigit).ToArray());
        if (cpf.Length > 11) cpf = cpf[..11];

        return cpf.Length switch
        {
            <= 3 => cpf,
            <= 6 => $"{cpf[..3]}.{cpf[3..]}",
            <= 9 => $"{cpf[..3]}.{cpf[3..6]}.{cpf[6..]}",
            _ => $"{cpf[..3]}.{cpf[3..6]}.{cpf[6..9]}-{cpf[9..]}"
        };
    }

    private string ApplyCnpjMask(string cnpj)
    {
        cnpj = new string(cnpj.Where(char.IsDigit).ToArray());
        if (cnpj.Length > 14) cnpj = cnpj[..14];

        return cnpj.Length switch
        {
            <= 2 => cnpj,
            <= 5 => $"{cnpj[..2]}.{cnpj[2..]}",
            <= 8 => $"{cnpj[..2]}.{cnpj[2..5]}.{cnpj[5..]}",
            <= 12 => $"{cnpj[..2]}.{cnpj[2..5]}.{cnpj[5..8]}/{cnpj[8..]}",
            _ => $"{cnpj[..2]}.{cnpj[2..5]}.{cnpj[5..8]}/{cnpj[8..12]}-{cnpj[12..]}"
        };
    }

    private string ApplyPhoneMask(string phone)
    {
        var clean = new string(phone.Where(char.IsDigit).ToArray());

        return clean.Length switch
        {
            <= 2 => clean,
            <= 6 => $"({clean[..2]}) {clean[2..]}",
            <= 10 => $"({clean[..2]}) {clean[2..6]}-{clean[6..]}",
            _ => $"({clean[..2]}) {clean[2..7]}-{clean[7..]}"
        };
    }

    private string ApplyCellPhoneMask(string phone)
    {
        var clean = new string(phone.Where(char.IsDigit).ToArray());

        return clean.Length switch
        {
            <= 2 => clean,
            <= 7 => $"({clean[..2]}) {clean[2..]}",
            _ => $"({clean[..2]}) {clean[2..7]}-{clean[7..]}"
        };
    }

    private async Task Salvar()
    {
        bool result = InsertMode
            ? await _clientService.AddAsync(Client)
            : await _clientService.EditAsync(Client);

        Notification.ExibirMensagem(
            result ? "Sucesso!" : "Erro!",
            result ? Severity.Success : Severity.Error);

        MudDialog.Close(DialogResult.Ok(true));
    }

    private void Cancel() => MudDialog.Cancel();
}