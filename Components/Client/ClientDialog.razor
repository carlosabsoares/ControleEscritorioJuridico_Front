                    <MudTextField @bind-Value="@Client.Name" Label="Nome" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" />
                </MudItem>

                <MudItem xs="12" md="3">
                    <MudSelect T="DocumentType"
                               Label="Tipo de Documento"
                               Value="Client.DocumentType"
                               ValueChanged="OnDocumentTypeChanged"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               FullWidth="true">
                        @foreach (var documentType in Enum.GetValues<DocumentType>())
                        {
                            <MudSelectItem Value="@documentType">@documentType</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudMask T="string"
                             @key="documentMaskKey"
                             Label="Número do Documento"
                             Mask="@documentMask"
                             @bind-Value="Client.DocumentNumber"
                             Variant="Variant.Outlined"
                             Margin="Margin.Dense"
                             FullWidth="true" />
                </MudItem>
            </MudGrid>

            <!-- Email + extras -->
            <MudGrid Class="mt-2">
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="@Client.Email" Label="Email" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" />
                </MudItem>

                @if (isNaturalPerson)
                {
