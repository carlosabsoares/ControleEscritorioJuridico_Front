                        <MudTextField @bind-Value="@Client.GeneralRegister" Label="RG" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" />
                    </MudItem>

                    <MudItem xs="12" md="4">
                        <MudTextField @bind-Value="@Client.Profession" Label="Profissão" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" />
                    </MudItem>
                }
            </MudGrid>

            <!-- Telefones -->
            <MudGrid Class="mt-2">
                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="@Client.PhoneNumber"
                                  Label="Telefone"
                                  Mask="@(new PatternMask("(00) 0000-0000"))"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  FullWidth="true" />
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="@Client.CellPhoneNumber"
                                  Label="Celular"
                                  Mask="@(new PatternMask("(00) 00000-0000"))"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  FullWidth="true" />
                </MudItem>

                <MudItem xs="12" md="4">
                    <MudTextField @bind-Value="@Client.ContactName"
                                  Label="Contato"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  FullWidth="true" />
                </MudItem>
            </MudGrid>

            <!-- Endereço -->
            <MudPaper Class="pa-4 mt-4" Elevation="1">
                <MudText Typo="Typo.h6">Endereço</MudText>

                <MudGrid Class="mt-2">
                    <MudItem xs="12" md="6">
                        <MudMask T="string"
                                 Label="CEP"
                                 Mask="@(new PatternMask("00000-000"))"
                                 @bind-Value="Client.Address.ZipCode"
                                 Variant="Variant.Outlined"
                                 FullWidth="true"
                                 Adornment="Adornment.End"
                                 AdornmentIcon="@Icons.Material.Filled.Search"
                                 OnAdornmentClick="OnFindCepClick" />
                    </MudItem>
                </MudGrid>

                <MudGrid Class="mt-2">
                    <MudItem xs="12" md="5">
                        <MudTextField @bind-Value="@Client.Address.Street" Label="Logradouro" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" />
                    </MudItem>

                    <MudItem xs="12" md="2">
                        <MudTextField @bind-Value="@Client.Address.Number" Label="Número" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" />
                    </MudItem>

                    <MudItem xs="12" md="5">
                        <MudTextField @bind-Value="@Client.Address.Complement" Label="Complemento" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" />
                    </MudItem>
                </MudGrid>

                <MudGrid Class="mt-2">
                    <MudItem xs="12" md="5">
                        <MudTextField @bind-Value="@Client.Address.Neighborhood" Label="Bairro" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" />
                    </MudItem>

                    <MudItem xs="12" md="5">
                        <MudTextField @bind-Value="@Client.Address.City" Label="Cidade" Variant="Variant.Outlined" Margin="Margin.Dense" FullWidth="true" />
                    </MudItem>

                    <MudItem xs="12" md="2">
                        <MudSelect T="string"
                                   Label="Estado"
                                   @bind-Value="Client.Address.State"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   FullWidth="true">
                            @foreach (var uf in Enum.GetValues<UfType>())
                            {
                                <MudSelectItem Value="@uf.ToString()">@uf</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                </MudGrid>

            </MudPaper>

        </EditForm>

    </DialogContent>

    <DialogActions>
        <MudButton Color="Color.Secondary" OnClick="Cancel">
            Fechar
        </MudButton>

        <MudButton Color="Color.Primary" OnClick="Salvar">
            Salvar
        </MudButton>
    </DialogActions>

</MudDialog>

