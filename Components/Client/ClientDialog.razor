<MudDialog MaxWidth="MaxWidth.Large" FullWidth="true">

    <DialogContent>

        <MudPaper Class="pa-3 mb-3" Elevation="0" Style="background-color: #f5f5f5;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@(InsertMode ? Icons.Material.Filled.PersonAdd : Icons.Material.Filled.Edit)" />
                <MudText Typo="Typo.h6">
                    @(InsertMode ? "Novo Cliente" : "Editar Cliente")
                </MudText>
            </MudStack>
        </MudPaper>

        <MudDivider Class="mb-3" />

        <EditForm Model="@Client">
            <DataAnnotationsValidator />

            <!-- Nome + Documento -->
            <MudGrid>
