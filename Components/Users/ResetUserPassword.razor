@using CEJ_WebApp.Model.Dto
@using MudBlazor
@inject IUserService _userService
@inject ISnackbar Snackbar

<MudDialog MaxWidth="MaxWidth.Small" FullWidth="true">

    <TitleContent>
        Alteração de senha
    </TitleContent>

    <DialogContent>

        <MudForm @ref="form">

            <MudStack Spacing="2">

                <MudTextField Label="Senha"
                              @bind-Value="password"
                              InputType="@passwordInput"
                              Immediate="true"
                              Required="true"
                              RequiredError="Informe a senha"
                              Adornment="Adornment.End"
                              AdornmentIcon="@passwordIcon"
                              OnAdornmentClick="TogglePasswordVisibility"
                              OnBlur="CheckPasswordStrength" />

                <MudProgressLinear Value="@passwordStrength"
                                   Color="@strengthColor"
                                   Rounded="true"
                                   Style="height:6px" />

                <MudText Typo="Typo.caption" Color="@strengthColor">
                    @strengthText
                </MudText>

                <MudTextField Label="Confirmar senha"
                              @bind-Value="confirmPassword"
                              InputType="@confirmPasswordInput"
                              Required="true"
                              RequiredError="Confirme a senha"
                              Adornment="Adornment.End"
                              AdornmentIcon="@confirmPasswordIcon"
                              OnAdornmentClick="ToggleConfirmPasswordVisibility"
                              Validation="@(new Func<string, string>(ValidatePasswordMatch))" />

            </MudStack>

        </MudForm>

    </DialogContent>

    <DialogActions>

        <MudButton Variant="Variant.Text"
                   OnClick="Cancel">
            Cancelar
        </MudButton>

        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Submit">
            Alterar senha
        </MudButton>

    </DialogActions>

</MudDialog>

@code {

    [CascadingParameter]
    public MudDialogInstance MudDialog { get; set; }

    private MudForm form;

    private string password;
    private string confirmPassword;

    private int passwordStrength;
    private string strengthText = "";
    private Color strengthColor = Color.Default;

    private InputType passwordInput = InputType.Password;
    private InputType confirmPasswordInput = InputType.Password;

    private string passwordIcon = Icons.Material.Filled.VisibilityOff;
    private string confirmPasswordIcon = Icons.Material.Filled.VisibilityOff;

    private void TogglePasswordVisibility()
    {
        if (passwordInput == InputType.Password)
        {
            passwordInput = InputType.Text;
            passwordIcon = Icons.Material.Filled.Visibility;
        }
        else
        {
            passwordInput = InputType.Password;
            passwordIcon = Icons.Material.Filled.VisibilityOff;
        }
    }

    private void ToggleConfirmPasswordVisibility()
    {
        if (confirmPasswordInput == InputType.Password)
        {
            confirmPasswordInput = InputType.Text;
            confirmPasswordIcon = Icons.Material.Filled.Visibility;
        }
        else
        {
            confirmPasswordInput = InputType.Password;
            confirmPasswordIcon = Icons.Material.Filled.VisibilityOff;
        }
    }

    private void CheckPasswordStrength()
    {
        int score = 0;

        if (string.IsNullOrEmpty(password))
        {
            passwordStrength = 0;
            strengthText = "";
            return;
        }

        if (password.Length >= 8) score++;
        if (password.Any(char.IsUpper)) score++;
        if (password.Any(char.IsDigit)) score++;
        if (password.Any(ch => "!@#$%^&*()_+-=[]{}|;':\",.<>/?".Contains(ch))) score++;

        passwordStrength = score * 25;

        switch (score)
        {
            case 1:
                strengthText = "Senha fraca";
                strengthColor = Color.Error;
                break;

            case 2:
                strengthText = "Senha média";
                strengthColor = Color.Warning;
                break;

            case 3:
                strengthText = "Senha boa";
                strengthColor = Color.Info;
                break;

            case 4:
                strengthText = "Senha forte";
                strengthColor = Color.Success;
                break;
        }
    }

    private string ValidatePasswordMatch(string value)
    {
        if (confirmPassword != password)
            return "As senhas não conferem";

        return null;
    }

    private async Task Submit()
    {
        await form.Validate();

        if (!form.IsValid)
            return;

        ChangePasswordResponseDto changePasswordResponseDto = new ChangePasswordResponseDto()
        {
                ConfirmPassword = confirmPassword,
                Password = password
        };

        var result = await _userService.ChangePasswordAsync(changePasswordResponseDto);

        if (!result)
        {
            ExibirMensagem("Error ao alterar senha.", Severity.Error);
        }
        else
        {
            ExibirMensagem("Senha alterada com sucesso", Severity.Success);
        }

        MudDialog.Close(DialogResult.Ok(password));
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private void ExibirMensagem(string mensagem, Severity serverity = Severity.Error)
    {
        var config = (SnackbarOptions options) =>
        {
            options.DuplicatesBehavior = SnackbarDuplicatesBehavior.Prevent;
        };

        Snackbar.Add(mensagem, serverity, configure: config, key: "User");
    }

}