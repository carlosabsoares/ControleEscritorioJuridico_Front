			<MudAppBar Elevation="0">
				<MudToggleIconButton @bind-Toggled="@_isNavOpen"
									 Edge="Edge.Start"
									 Icon="@Icons.Material.Filled.Menu"
									 Title="Mostrar menu"
									 Color="Color.Surface"
									 ToggledIcon="@Icons.Material.Filled.MenuOpen"
									 ToggledTitle="Esconder menu"
									 ToggledColor="Color.Surface">
				</MudToggleIconButton>

				<MudSpacer />

				<MudToggleIconButton @bind-Toggled="_isDarkMode"
									 Edge="Edge.Start"
									 Icon="@Icons.Material.Filled.DarkMode"
									 ToggledIcon="@Icons.Material.Filled.LightMode"
									 Title="Modo escuro"
									 ToggledTitle="Modo claro"
									 Color="@(_isDarkMode ? Color.Warning : Color.Surface)"
									 ToggledColor="@(_isDarkMode ? Color.Warning : Color.Surface)" />

				<!-- MENU DO USUÁRIO -->

				<MudMenu>
					<ActivatorContent>
						<MudButton StartIcon="@Icons.Material.Filled.AccountCircle"
								   Variant="Variant.Text"
								   Color="Color.Surface">
							@UserSessionInformation.Username
						</MudButton>
					</ActivatorContent>
					<ChildContent>
						
						<MudMenuItem Icon="@Icons.Material.Filled.Password" OnClick="@OpenDialogAsync">
							Alterar Senha
						</MudMenuItem>

						<MudDivider />

						<MudMenuItem Icon="@Icons.Material.Filled.Logout"
									 Color="Color.Error"
									 OnClick="@Logout">
							Sair
						</MudMenuItem>
					</ChildContent>
				</MudMenu>

				@* 				<div class="top-row px-4 auth">
					<div class="ms-auto">
						<div class="dropdown">
							<button class="btn btn-light dropdown-toggle" 
							        type="button" 
									data-bs-toggle="dropdown">
								<span class="me-2">👤</span> @UserSessionInformation.Username
							</button>

							<ul class="dropdown-menu dropdown-menu-end">
								<li>
									<a class="dropdown-item" @onclick="OpenDialogAsync">Trocar a Senha</a>
								</li>
								<li><hr class="dropdown-divider"></li>
								<li>
									<button class="dropdown-item" @onclick="Logout">Sair</button>
								</li>
							</ul>
						</div>
					</div>
				</div> *@
			</MudAppBar>

			<MudDrawer @bind-Open="_isNavOpen" Elevation="1">
				<MudDrawerHeader>
					<MudText Typo="Typo.h6">CEJ</MudText>
				</MudDrawerHeader>
				<NavMenu />
			</MudDrawer>

			<MudMainContent>
				<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="my-4 pt-4">
					@Body
				</MudContainer>
			</MudMainContent>

		</MudLayout>

	</Authorized>
	<NotAuthorized>
		@{
			NavigationManager.NavigateTo("login");
		}
	</NotAuthorized>
</AuthorizeView>


@code {
	bool _isNavOpen = true;
	bool _isDarkMode = true;

	MudThemeProvider? _mudThemeProvider;

	private async Task OpenDialogAsync()
	{
		var parameters = new DialogParameters();
		var options = new DialogOptions { CloseButton = true, CloseOnEscapeKey = true };
        
		var dialog = await DialogService.ShowAsync<ResetUserPassword>("Redefinir Senha", parameters);
        
		var result = await dialog.Result;
		if (!result.Cancelled)
		{
			// Sucesso!
		}
	}

	
	private string GetUserButtonClass()
	{
		return _isDarkMode ? "btn-dark-mode" : "btn-light-mode";
	}

	private string GetUserButtonStyle()
	{
		if (_isDarkMode)
		{
			return "background-color: #333; color: white; border-color: #444;";
		}
		else
		{
			return "background-color: #f8f9fa; color: #333; border-color: #ddd;";
			//return "mud-theme-primary;";
		}
	}

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (firstRender)
		{
			_isDarkMode = true;
			_isDarkMode = await _mudThemeProvider!.GetSystemPreference();
			StateHasChanged();
		}
	}

	public async Task Logout()
	{
		AuthService.Logout();
		NavigationManager.NavigateTo("/login");

	}
}
