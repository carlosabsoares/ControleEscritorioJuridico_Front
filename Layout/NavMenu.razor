@using CEJ_WebApp.Model
@inject UserSessionInformation UserSessionInformation

<MudPaper Width="250px" Class="d-inline-flex py-3" Elevation="0">
	<MudNavMenu Class="mud-width-full">
		<MudDivider Class="my-2" />
		<MudNavLink Href="/dashboard" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
		<MudNavLink Href="/clients" Icon="@Icons.Material.Filled.Contacts">Clientes</MudNavLink>
		<MudNavLink Href="/Process" Icon="@Icons.Material.Filled.Balance">Processos</MudNavLink>

		@if (UserSessionInformation.Role != Model.Enum.UserRoleType.Operador)
		{
			<MudNavGroup Title="Painel Administrativo" Icon="@Icons.Material.Filled.AdminPanelSettings" Expanded="true">
				<MudNavLink Href="/users" Icon="@Icons.Material.Filled.Person">Usuários</MudNavLink>
			</MudNavGroup>
		}
	</MudNavMenu>
</MudPaper>

